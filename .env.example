# GoClaude - 环境变量示例
#
# 此文件仅承担一项职责：注入凭证（API Key）。
# 复制为 .env 后填入实际值：cp .env.example .env
#
# 所有"参数类"配置（model / temperature / max_tokens /
# base_url / permission_mode / timeout / ...）请改写 YAML：
#   - configs/default.yaml         (内置默认基线)
#   - ~/.goclaude/config.yaml      (用户级覆盖)
#   - <project>/.goclaude.yaml     (项目级覆盖)

# DeepSeek API（OpenAI 兼容协议）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
